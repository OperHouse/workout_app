<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.WorkoutApp"
        parent="Theme.Material3.DayNight.NoActionBar">

        <item name="colorPrimary">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>

        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
    </style>

    <style name="Theme.WorkoutApp" parent="Base.Theme.WorkoutApp" />

    <style name="ThemeOverlay.WorkoutApp.FullscreenContainer" parent="">
        <item name="fullscreenBackgroundColor">@color/light_blue_600</item>
        <item name="fullscreenTextColor">@color/light_blue_A200</item>
    </style>


    <style name="CustomCalendarTheme"
        parent="ThemeOverlay.Material3.MaterialCalendar">

        <!-- ТЕМА ДИАЛОГА -->
        <item name="materialAlertDialogTheme">@style/MyCalendarDialog</item>

        <!-- ОСНОВНЫЕ ЦВЕТА MATERIAL3 -->
        <item name="colorSurface">@color/background_1</item>
        <item name="colorOnSurface">@color/white</item>

        <!-- ВАЖНО: контейнеры Material3 -->
        <item name="colorSurfaceContainerHighest">@color/background_1</item>
        <item name="colorSurfaceContainerHigh">@color/background_1</item>
        <item name="colorSurfaceContainer">@color/background_1</item>

        <!-- Цвет текста по умолчанию -->
        <item name="colorOnSurfaceVariant">@color/white</item>

        <!-- Кнопки OK / Cancel -->
        <item name="colorPrimary">@color/white</item>

        <!-- Стили календаря -->
        <item name="materialCalendarStyle">@style/MyCalendarStyle</item>
        <item name="materialCalendarHeaderLayout">@style/MyCalendarHeader</item>
        <item name="materialCalendarHeaderTitle">@style/MyCalendarHeaderTitle</item>
    </style>

</resources>
