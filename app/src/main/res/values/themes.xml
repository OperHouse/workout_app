<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.WorkoutApp" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="colorPrimary">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>

        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
    </style>

    <style name="Theme.WorkoutApp" parent="Base.Theme.WorkoutApp" />

    <style name="ThemeOverlay.WorkoutApp.FullscreenContainer" parent="">
        <item name="fullscreenBackgroundColor">@color/light_blue_600</item>
        <item name="fullscreenTextColor">@color/light_blue_A200</item>
    </style>


    <style name="CustomCalendarTheme" parent="ThemeOverlay.Material3.MaterialCalendar">

        <!-- ТЕМА ДИАЛОГА -->
        <item name="materialAlertDialogTheme">@style/MyCalendarDialog</item>

        <!-- ОСНОВНЫЕ ЦВЕТА MATERIAL3 -->
        <item name="colorSurface">@color/background_1</item>
        <item name="colorOnSurface">@color/white</item>

        <!-- ВАЖНО: контейнеры Material3 -->
        <item name="colorSurfaceContainerHighest">@color/background_1</item>
        <item name="colorSurfaceContainerHigh">@color/background_1</item>
        <item name="colorSurfaceContainer">@color/background_1</item>

        <!-- Цвет текста по умолчанию -->
        <item name="colorOnSurfaceVariant">@color/white</item>

        <!-- Кнопки OK / Cancel -->
        <item name="colorPrimary">@color/white</item>

        <!-- Стили календаря -->
        <item name="materialCalendarStyle">@style/MyCalendarStyle</item>
        <item name="materialCalendarHeaderLayout">@style/MyCalendarHeader</item>
        <item name="materialCalendarHeaderTitle">@style/MyCalendarHeaderTitle</item>
    </style>

    <style name="SettingsCategoryTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">#8E8E93</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="SettingsCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">20dp</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="cardBackgroundColor">@color/black2</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/light_gray_stroke</item>
    </style>

    <style name="SettingsContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">4dp</item>
    </style>

    <style name="ModernDestructiveButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:textColor">#FF8A80</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">16dp</item>
    </style>

    <style name="SettingsDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0.5dp</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:background">@color/divider</item>
    </style>

    <style name="CustomAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.MediumComponent</item>
        <item name="android:background">@color/black2</item>
    </style>

    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>

</resources>
