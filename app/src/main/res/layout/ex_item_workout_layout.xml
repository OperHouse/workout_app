<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:elevation="8dp"
    android:paddingTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="19dp">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="10dp"
            android:layout_marginStart="5dp"
            android:layout_marginBottom="5dp"
            android:background="@drawable/card_border">

            <TextView
                android:id="@+id/exerciseName_OUTSIDE_CARD_TV"
                style="@style/TextStyle.Big.Bold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="10dp"
                android:gravity="start|center_vertical"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="@string/exercise_name_title"
                app:layout_constraintEnd_toStartOf="@+id/addSet_OUTSIDE_CARD_Btn"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            </TextView>

            <TextView
                android:id="@+id/typeExercise_OUTSIDE_CARD_TV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="left|center"
                android:text="@string/exercise_type_plug"
                android:textColor="@color/white"

                app:layout_constraintStart_toStartOf="@+id/exerciseName_OUTSIDE_CARD_TV"
                app:layout_constraintTop_toBottomOf="@+id/exerciseName_OUTSIDE_CARD_TV">

            </TextView>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/addSet_OUTSIDE_CARD_Btn"
                style="@style/SmallButtonWithIc_Plus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:gravity="start|center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="@string/set"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/exerciseName_OUTSIDE_CARD_TV">

            </com.google.android.material.button.MaterialButton>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/strength_OUTSIDE_CARD_CL"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp"
                android:layout_marginBottom="10dp"
                app:layout_constraintTop_toBottomOf="@+id/typeExercise_OUTSIDE_CARD_TV"
                tools:layout_editor_absoluteX="10dp">

                <TextView
                    android:id="@+id/weight_OUTSIDE_CARD_TV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="60dp"
                    android:gravity="left|center"
                    android:text="@string/weight"
                    style="@style/TextStyle.Small.Bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                </TextView>

                <TextView
                    android:id="@+id/reps_OUTSIDE_CARD_TV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="50dp"
                    android:gravity="left|center"
                    android:text="@string/reps"
                    style="@style/TextStyle.Small.Bold"
                    app:layout_constraintBottom_toBottomOf="@+id/weight_OUTSIDE_CARD_TV"
                    app:layout_constraintStart_toEndOf="@+id/weight_OUTSIDE_CARD_TV"
                    app:layout_constraintTop_toTopOf="parent">

                </TextView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardio_OUTSIDE_CARD_CL"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                app:layout_constraintTop_toBottomOf="@+id/strength_OUTSIDE_CARD_CL"
                tools:layout_editor_absoluteX="10dp">

                <TextView
                    android:id="@+id/time_OUTSIDE_CARD_TV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="30dp"
                    android:gravity="left|center"
                    android:text="@string/time"
                    style="@style/TextStyle.Small.Bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                </TextView>

                <TextView
                    android:id="@+id/temp_OUTSIDE_CARD_TV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="60dp"
                    android:gravity="left|center"
                    android:text="@string/temp"
                    style="@style/TextStyle.Small.Bold"
                    app:layout_constraintBottom_toBottomOf="@+id/time_OUTSIDE_CARD_TV"
                    app:layout_constraintStart_toEndOf="@+id/time_OUTSIDE_CARD_TV"
                    app:layout_constraintTop_toTopOf="parent">

                </TextView>

                <TextView
                    android:id="@+id/distance_OUTSIDE_CARD_TV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="50dp"
                    android:gravity="left|center"
                    android:text="@string/distance"
                    style="@style/TextStyle.Small.Bold"
                    app:layout_constraintBottom_toBottomOf="@+id/temp_OUTSIDE_CARD_TV"
                    app:layout_constraintStart_toEndOf="@+id/temp_OUTSIDE_CARD_TV"
                    app:layout_constraintTop_toTopOf="parent">

                </TextView>

            </androidx.constraintlayout.widget.ConstraintLayout>



            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/OUTSIDE_CARD_inner_RV"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:listitem="@layout/set_cardio_item_card"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@+id/cardio_OUTSIDE_CARD_CL">

            </androidx.recyclerview.widget.RecyclerView>

            <Button
                android:id="@+id/deleteExercise_OUTSIDE_CARD_BTN"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="10dp"
                style="@style/BigButton"
                android:text="@string/delete_exercise"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/OUTSIDE_CARD_inner_RV">

            </Button>

        </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.cardview.widget.CardView>